# ==============================================================================
# Environment Variables Template
# ==============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The .env file is loaded by python-dotenv and should NEVER be committed to git.
# ==============================================================================

# Optional: Override Wikidata endpoint (useful for local testing with a mirror)
# WIKIDATA_SPARQL_ENDPOINT=https://query.wikidata.org/sparql

# Optional: Override config file path
# CONFIG_PATH=config.yaml

# Optional: Set log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# Optional: Google Drive mount path for Colab
# GDRIVE_MOUNT_PATH=/content/drive/MyDrive/kg_project
